# Cargo-installed tools (idasen-control)
export PATH="$PATH:$HOME/.cargo/bin"

# fnm (Node version manager)
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd)"
fi

# Neovim
alias vim="nvim"
alias vi="nvim"
alias v="nvim"
export EDITOR="nvim"

# Pi without the explain-only tutor mode
alias pi-full='command pi --no-extensions --system-prompt ""'

# Machine-local overrides (API keys, one-off aliases, etc.)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# Starship prompt (init last)
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"
