# Go
export PATH="$PATH:$HOME/go/bin"

# Rust
export PATH="$PATH:$HOME/.cargo/bin"

# fnm (Node version manager)
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd)"
fi

# Neovim
alias vim="nvim"
alias vi="nvim"
alias v="nvim"
export EDITOR="nvim"

# one-sec — mindful pause before distracting terminal apps
# [[ -f ~/.config/one-sec/init.zsh ]] && source ~/.config/one-sec/init.zsh

# Machine-local overrides (API keys, one-off aliases, etc.)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
