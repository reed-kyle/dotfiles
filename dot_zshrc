# Neovim
alias vim="nvim"
alias vi="nvim"
alias v="nvim"
export EDITOR="nvim"

# Chezmoi
cz() {
  case "$1" in
    push) cd ~/.local/share/chezmoi && git add -A && git commit && git push ;;
    pull) chezmoi update ;;
    *) chezmoi "$@" ;;
  esac
}

# Machine-local overrides (API keys, one-off aliases, etc.)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
