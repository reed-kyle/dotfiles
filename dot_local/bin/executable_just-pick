#!/usr/bin/env bash
# fzf-pick a just recipe (meant to run inside a tmux popup) and run it
# in the pane the popup was opened over. If that pane isn't sitting at
# a shell prompt (e.g. nvim), run it in a "tasks" window instead.
# Recipes that manage their own window (via tmux-task) take over from
# there.
set -euo pipefail
export PATH="/opt/homebrew/bin:$HOME/.local/bin:$PATH"

if ! list=$(just --list --unsorted 2>/dev/null); then
  tmux display-message "just-pick: no justfile here"
  exit 0
fi

choice=$(sed '1d; s/^ *//' <<<"$list" | fzf --prompt='just ❯ ' --reverse --no-info) || exit 0
recipe=${choice%% *}

pane=$(tmux display-message -p '#{pane_id}')
panecmd=$(tmux display-message -p -t "$pane" '#{pane_current_command}')
case "$panecmd" in
  zsh | bash | sh | fish)
    tmux send-keys -t "$pane" "just $recipe" Enter
    ;;
  *)
    tmux-task tasks "just $recipe"
    ;;
esac
